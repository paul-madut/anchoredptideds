# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Used by the deploy worker + admin actions. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Deploy bundle (public URLs the target WP downloads during provisioning) ---
# Point these at the zips in ap/build-zips/ hosted somewhere the target can reach
# (Supabase Storage public bucket, GitHub raw, S3, etc.).
BUNDLE_THEME_URL=https://YOUR-CDN/anchored-peptides.zip
BUNDLE_HOMEPAGE_URL=https://YOUR-CDN/anchored-peptides-homepage.zip
BUNDLE_COMING_SOON_URL=https://YOUR-CDN/anchored-peptides-coming-soon.zip
PRODUCTS_CSV_URL=https://YOUR-CDN/ap-products-final.csv

# Optional shared secret that must match the target's `ap_provision_secret` option.
PROVISION_SECRET=

# --- OpenAI (powers "Let AI choose" text + hero image generation) ---
OPENAI_API_KEY=
# Optional model overrides:
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# --- Optional non-OpenAI image provider fallback (used only if OPENAI_API_KEY is unset) ---
IMAGE_API_URL=
IMAGE_API_KEY=

# --- Admin access ---
# Comma-separated allowlist of emails permitted into /admin.
ADMIN_EMAILS=you@example.com
